# Tier 1 — reverse image search via SerpAPI (Google Lens engine).
# Microsoft retired the Bing Search APIs on 2025-08-11.
# Live lookup only fires when the /verify request includes a `url` field;
# uploaded bytes are matched against data/reverse_cache.json instead.
SERPAPI_API_KEY=

# Tier 4 — fact-check corroboration
GOOGLE_FACTCHECK_API_KEY=

# Tier 3 — HF deepfake classifier (Inference API)
HF_TOKEN=

# Local API port
PORT=8000

# Comma-separated extra CORS origins, on top of the localhost defaults.
# In Render/Vercel production:
#   CORS_ORIGINS=https://<your-vercel-domain>.vercel.app,https://<preview>.vercel.app
CORS_ORIGINS=

# Frontend → API base URL (used by Next.js at build time + runtime).
# Local dev defaults to http://localhost:8000 if unset.
NEXT_PUBLIC_API_BASE=
