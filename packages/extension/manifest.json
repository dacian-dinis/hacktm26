{
  "manifest_version": 3,
  "name": "Veritas Stack",
  "version": "0.1.0",
  "description": "Right-click any image to run it through the Veritas Stack verification workbench — evidence, not verdicts.",
  "permissions": ["contextMenus", "storage", "scripting", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Veritas Stack — open options"
  }
}
